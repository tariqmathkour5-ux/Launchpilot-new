# LaunchPilot Production .gitignore

# Environment & Secrets - NEVER COMMIT
.env
.env.*
!.env.example
.env.local
.env.development
.env.production
.env.test
*.env

# Node.js & Package Managers
node_modules/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
npm-cache/
.yarn/
.yarn-cache/

# Build Outputs & Cache
.next/
.next.zip
*.next/*
dist/
build/
out/
*.tsbuildinfo
.cache/

# Coverage & Testing
coverage/
.nyc_output/

# Database Files
*.db
*.sqlite
*.sqlite3
prisma/dev.db
prisma/*.db-journal
prisma/**/*.db
prisma/**/*.db-journal

# Archives & Backups
*.zip
*.tar
*.tar.gz
backup/
backups/
archives/
output/
import_report.json
merge_report.json

# AI Knowledge Base (Large Datasets)
LaunchPilot_AI_KnowledgeBase/
project/data/
project/LaunchPilot_AI_KnowledgeBase.zip

# IDE & Editor Files
.vscode/
.idea/
.DS_Store

# Logs
logs/
log/
.bolt/  
project/build_kb.py

# Temporary/Scratch/Malformed Files (files with special characters)
*.tmp
*.bak
*!
*.*!
t.*
x.*