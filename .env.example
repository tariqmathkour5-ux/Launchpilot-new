# LaunchPilot Environment Variables
# Copy this file to .env and fill in your values

# =============================================================================
# REQUIRED FOR BASIC FUNCTIONALITY
# =============================================================================

# Database (PostgreSQL for production, SQLite for local development)
DATABASE_URL="file:./dev.db"
DIRECT_URL=""

# Authentication - NextAuth.js
NEXTAUTH_SECRET="YOUR_NEXTAUTH_SECRET"
NEXTAUTH_URL="http://localhost:3000"

# Email - Resend
RESEND_API_KEY=""
RESEND_FROM_EMAIL="LaunchPilot <onboarding@resend.dev>"

# Site Configuration
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
NEXT_PUBLIC_SITE_NAME="LaunchPilot"

# =============================================================================
# REQUIRED FOR PAYMENT FEATURES
# =============================================================================

# Stripe
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""

# =============================================================================
# OPTIONAL: OAUTH PROVIDERS
# =============================================================================

# GitHub OAuth
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""

# Google OAuth
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Enable/Disable Google OAuth
NEXT_PUBLIC_GOOGLE_ENABLED="false"

# =============================================================================
# OPTIONAL: SUPABASE
# =============================================================================

NEXT_PUBLIC_SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_ANON_KEY=""
SUPABASE_SERVICE_ROLE_KEY=""

# =============================================================================
# OPTIONAL: AI PROVIDERS
# =============================================================================

# OpenAI
OPENAI_API_KEY=""

# Google Gemini
GEMINI_API_KEY=""

# Groq
GROQ_API_KEY=""

# =============================================================================
# OPTIONAL: TELEGRAM NOTIFICATIONS
# =============================================================================

TELEGRAM_BOT_TOKEN=""
TELEGRAM_ADMIN_CHAT_ID=""

# =============================================================================
# OPTIONAL: MONITORING & ANALYTICS
# =============================================================================

# Sentry
NEXT_PUBLIC_SENTRY_DSN=""
SENTRY_AUTH_TOKEN=""

# Vercel Analytics (automatically configured when deployed on Vercel)
# NEXT_PUBLIC_VERCEL_ANALYTICS_ID=""

# =============================================================================
# OPTIONAL: GROWTH AUTOMATION
# =============================================================================

GROWTH_WEBHOOK_URL=""
ENABLE_GROWTH_WEBHOOKS="false"
GROWTH_WEBHOOK_SECRET=""

# =============================================================================
# OPTIONAL: PAYTABS (Alternative Payment Gateway)
# =============================================================================

PAYTABS_SERVER_KEY=""
PAYTABS_PROFILE_ID=""

# =============================================================================
# OPTIONAL: ISR REVALIDATION
# =============================================================================

REVALIDATE_SECRET=""